# ---------- LLM-Provider ----------
# Empfohlener Default: Google AI Studio Free Tier (Gemini 2.5 Flash).
# 1500 Requests/Tag gratis, OpenAI-kompatibel, keine Hardware-Voraussetzungen.
# API-Key (kostenlos, ohne Kreditkarte) unter: https://aistudio.google.com/apikey

LLM_PROVIDER=openai

OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_API_KEY=
OPENAI_MODEL=gemini-2.5-flash

# ---------- Alternative Provider ----------
# Um zu wechseln: LLM_PROVIDER oben anpassen und unten die entsprechenden Werte fuellen.

# --- OpenRouter (Gemma 4, Qwen, Llama, viele Modelle, auch Free-Tier) ---
# LLM_PROVIDER=openai
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...
# OPENAI_MODEL=google/gemma-4-26b:free     (oder qwen/qwen-2.5-72b-instruct)

# --- Alibaba Qwen Cloud (DashScope) ---
# OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-plus

# --- Anthropic Claude (schnell, kostenpflichtig) ---
# LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# --- Ollama (lokal, offline-tauglich, Gemma 4 E2B auch ohne GPU) ---
# LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_CTX=16384

# ---------- Fetcher ----------
# Maximale Zeichenzahl des Gesetzestext-Auszugs an den LLM.
# Gemini 2.5 Flash hat 1M Context - hier kann 80000+ stehen.
# Bei lokalem Ollama mit num_ctx=16384 eher 30000-40000 lassen.
FULLTEXT_MAX_CHARS=60000
